import {
  "ubugeeei-prod/web_highlighter/src" @core,
  "ubugeeei-prod/web_highlighter/addons/paper" @paper,
  "ubugeeei-prod/web_highlighter/addons/ush" @ush,
}

supported_targets = "wasm-gc"

pkgtype(kind: "executable")

options(
  link: {
    "wasm-gc": {
      "exports": [ "analyze_request", "theme_wire", "themes_wire" ],
      "use-js-builtin-string": true,
    },
  },
)
